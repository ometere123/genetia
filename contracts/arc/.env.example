# Genetia — Arc contracts deploy env
#
# Copy to `.env` (NOT committed) and fill in the three values below.
# Foundry reads `.env` automatically when you `source` it before running
# `forge script`.

# ── Arc Testnet RPC ───────────────────────────────────────────────────────────
ARC_TESTNET_RPC_URL=https://rpc.testnet.arc.network

# ── Deployer wallet (pays gas to publish MarketFactory) ───────────────────────
# This wallet needs Arc testnet gas. Funding source:
#   https://faucet.testnet.arc.network  (or whichever Arc faucet you use)
# Format: 0x-prefixed 64-char hex.
PRIVATE_KEY=

# ── Resolver address (baked into every market) ────────────────────────────────
# This is the ADDRESS that corresponds to ARC_RESOLVER_PRIVATE_KEY in
# frontend/.env.local. The relayer pipeline signs `resolve(bool)` calls
# with that private key, so the address must match for the call to be
# accepted by the PredictionMarket contract.
RESOLVER_ADDRESS=0xFffC471399903Bf35DF41A0cD1DB1165D525B7af

# ── Optional: Arc explorer verification ───────────────────────────────────────
# Used by foundry.toml's [etherscan] section if you want auto-verify.
# Get one from https://testnet.arcscan.app or Blockscout.
ARCSCAN_API_KEY=
