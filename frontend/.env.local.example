# ──────────────────────────────────────────────────────────────────────────────
# Genetia — Environment Variables
# Copy this file to .env.local and fill in all values.
# NEVER commit .env.local to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── Arc Testnet ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_ARC_CHAIN_ID=5042002
NEXT_PUBLIC_ARC_RPC_URL=https://rpc.testnet.arc.network

# ── Smart Contracts ───────────────────────────────────────────────────────────
# Populated after: cd contracts/arc && forge script script/Deploy.s.sol --broadcast
NEXT_PUBLIC_MARKET_FACTORY_ADDRESS=

# ── Privy Authentication ──────────────────────────────────────────────────────
# Privy is used for AUTHENTICATION ONLY (email + external EVM wallet login).
# Privy embedded wallets are NOT used as the Genetia trading wallet.
# Create an app at https://dashboard.privy.io
# Enable login methods: Email, External Wallet
# Disable: Embedded Wallets
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_ID=
PRIVY_APP_SECRET=
# Legacy alias still read as a fallback if PRIVY_APP_SECRET is missing.
PRIVY_SECRET=

# ── Circle Developer-Controlled SCA Wallets ───────────────────────────────────
# Every Genetia user is provisioned exactly one Circle Developer-Controlled
# Smart Contract Account wallet on ARC-TESTNET. This is the user's Genetia
# Wallet — the only wallet used for deposits, balances, bets, settlement,
# winnings, and withdrawals.
#
# Register at https://console.circle.com → enable Developer-Controlled Wallets
# → create a Wallet Set on ARC-TESTNET → copy its ID below.
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=
CIRCLE_ENTITY_SECRET_CIPHERTEXT=
CIRCLE_WALLET_SET_ID=
CIRCLE_BLOCKCHAIN=ARC-TESTNET
CIRCLE_ACCOUNT_TYPE=SCA
# Optional: USDC token ID from Circle's token registry (for transfers)
CIRCLE_USDC_TOKEN_ID=

# ── Database (PostgreSQL + Prisma) ────────────────────────────────────────────
# Local dev: postgresql://postgres:postgres@localhost:5432/genetia
# Production: Supabase, Neon, Railway, or any managed Postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/genetia

# ── GenLayer (Studionet) ──────────────────────────────────────────────────────
# Studionet — hosted GenLayer simulator (chain id 61999)
#   RPC:      https://studio.genlayer.com/api
#   Explorer: https://explorer-studio.genlayer.com
#   Studio:   https://studio.genlayer.com
# Deploy the MarketResolver contract from contracts/genlayer/market_resolver.py
# via the Studio UI or `genlayer deploy`, then paste its address below.
GENLAYER_RPC=https://studio.genlayer.com/api
GENLAYER_CHAIN_ID=61999
# Live MarketResolver deployment on Studionet:
GENLAYER_CONTRACT_ADDRESS=0x593741331b13cF8683fb62b720D7d1e863d1D261
# A funded GenLayer account private key used by the relayer pipeline to call
# resolve_market on behalf of the backend.
GENLAYER_RELAYER_PRIVATE_KEY=

# ── Arc resolver ──────────────────────────────────────────────────────────────
# Private key that the pipeline uses to call resolve(bool) on Arc
# PredictionMarket contracts (must match each market's `resolver` address).
ARC_RESOLVER_PRIVATE_KEY=

# ── Arc factory operator ──────────────────────────────────────────────────────
# Private key authorised to call MarketFactory.createMarket().
# Either the factory owner (the deployer of contracts/arc/script/Deploy.s.sol)
# or any address you've added via MarketFactory.setOperator(addr, true).
# Required for the admin "approve suggestion" flow to mirror new markets
# onto Arc. If missing, approvals still work — they just stay DB-only.
ARC_OPERATOR_PRIVATE_KEY=

# ── Blockscout (Arc explorer API) ─────────────────────────────────────────────
# Used by the admin dashboard to enrich tx/log views.
BLOCKSCOUT_API_KEY=proapi_gnrvYMAKmATMI8eDUrWpGDojaRv0A3tRVq4WteaT8GcenzTN6FsgeHJU794En2Ssi_dsWkce

# ── Cron / resolver pipeline trigger ──────────────────────────────────────────
# Required to call POST /api/cron/resolve-markets. The standalone relayer/
# service and any external scheduler (Vercel cron, GitHub Actions) must
# send this in `Authorization: Bearer ${CRON_SECRET}`.
CRON_SECRET=

# ── Admin ─────────────────────────────────────────────────────────────────────
# Wallet address granted admin dashboard access (lowercase, 0x-prefixed)
NEXT_PUBLIC_ADMIN_ADDRESS=
ADMIN_WALLET_ADDRESS=

# Admin dashboard URL slug — keep this secret
# Example: "k7mz3x9p-ops"  → /k7mz3x9p-ops
NEXT_PUBLIC_ADMIN_SLUG=admin
ADMIN_SLUG=admin
