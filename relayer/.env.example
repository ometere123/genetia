# Genetia Relayer — env vars
#
# This service is a thin HTTP pinger. It pokes the Next.js cron endpoint
# every POLL_INTERVAL_MS so the resolver pipeline runs on a schedule.

# Base URL of the Genetia Next.js app
APP_URL=http://localhost:3000

# Must match CRON_SECRET in the Next.js app's .env.local
CRON_SECRET=

# How often to wake the pipeline (default 60s)
POLL_INTERVAL_MS=60000
